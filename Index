<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Raptor Alert — Demo</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
:root {
  --lockout:#2563EB; --lockdown:#DC2626; --evacuate:#16A34A;
  --shelter:#EA580C; --hold:#7C3AED;
  --bg:#F2F2F7; --card:#fff; --text:#1C1C1E; --muted:#6E6E73;
  --border:#E5E5EA; --orange:#FF9500; --green:#16A34A; --red:#DC2626;
}
body { background:#C8C8CC; display:flex; justify-content:center; padding:20px; font-family:-apple-system,BlinkMacSystemFont,'Helvetica Neue',sans-serif; min-height:100vh; }
.phone { width:390px; background:var(--bg); border-radius:50px; box-shadow:0 30px 80px rgba(0,0,0,.35),inset 0 0 0 1px rgba(255,255,255,.2); overflow:hidden; display:flex; flex-direction:column; min-height:844px; }
.status-bar { background:#fff; padding:14px 24px 10px; display:flex; justify-content:space-between; align-items:center; font-size:15px; font-weight:600; color:var(--text); flex-shrink:0; }
.si { display:flex; align-items:center; gap:6px; }
.screen { display:none; flex:1; flex-direction:column; overflow:hidden; }
.screen.active { display:flex; }

/* ── NAV BAR ── */
.nav { background:#fff; padding:14px 20px 12px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(–border); flex-shrink:0; }
.nav-title { font-size:17px; font-weight:600; }
.back { color:#007AFF; font-size:17px; cursor:pointer; min-width:40px; }
.nav-r { min-width:40px; text-align:right; }

/* ── SETUP ── */
#setupScreen { background:#fff; padding:36px 28px; align-items:center; overflow-y:auto; }
.logo { width:68px; height:68px; background:#C8102E; clip-path:polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%); display:flex; align-items:center; justify-content:center; font-size:26px; font-weight:900; color:#fff; margin:0 auto 18px; }
.setup-title { font-size:22px; font-weight:700; margin-bottom:6px; text-align:center; }
.setup-sub { font-size:14px; color:var(–muted); margin-bottom:28px; text-align:center; line-height:1.5; }
.sf { width:100%; margin-bottom:13px; }
.sf label { display:block; font-size:11px; font-weight:700; color:var(–muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:5px; }
.sf input { width:100%; background:var(–bg); border:1.5px solid var(–border); border-radius:10px; padding:11px 14px; font-size:16px; color:var(–text); outline:none; font-family:inherit; transition:border-color .2s; }
.sf input:focus { border-color:var(–orange); }
.btn-primary { width:100%; background:var(–orange); color:#fff; border:none; border-radius:12px; padding:15px; font-size:17px; font-weight:600; cursor:pointer; font-family:inherit; }
.btn-primary:active { opacity:.85; }
.btn-primary:disabled { background:#C7C7CC; cursor:not-allowed; }

/* ── HOME ── */
#homeScreen { background:#fff; }
.srp-scroll { flex:1; overflow-y:auto; padding-bottom:8px; }
.srp-grid { padding:16px 20px 0; display:grid; grid-template-columns:1fr 1fr; gap:20px 14px; justify-items:center; }
.srp-btn { display:flex; flex-direction:column; align-items:center; gap:7px; cursor:pointer; }
.srp-circle { width:136px; height:136px; border-radius:50%; display:flex; align-items:center; justify-content:center; transition:transform .12s; box-shadow:0 4px 14px rgba(0,0,0,.15); }
.srp-btn:active .srp-circle { transform:scale(.93); }
.srp-circle svg { width:68px; height:68px; }
.srp-lbl { font-size:13px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; }
.hold-row { grid-column:1/-1; display:flex; justify-content:center; }
.team-assist { margin:16px 20px 6px; background:#fff; border:1.5px solid var(–border); border-radius:14px; padding:15px; display:flex; align-items:center; justify-content:center; gap:10px; font-size:14px; font-weight:700; letter-spacing:.04em; text-transform:uppercase; cursor:pointer; }
.tab-bar { background:#fff; border-top:1px solid var(–border); display:flex; padding:8px 0 22px; flex-shrink:0; }
.tab-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; cursor:pointer; font-size:10px; font-weight:500; color:var(–muted); }
.tab-item.active { color:var(–orange); }
.tab-item svg { width:24px; height:24px; }

/* ── HAMBURGER MENU ── */
.menu-overlay { display:none; position:absolute; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,.4); z-index:50; }
.menu-overlay.open { display:block; }
.side-menu { position:absolute; top:0; left:-100%; width:75%; height:100%; background:#fff; z-index:51; transition:left .25s ease; padding-top:60px; }
.side-menu.open { left:0; }
.menu-header { padding:16px 20px 12px; border-bottom:1px solid var(–border); }
.menu-school { font-size:16px; font-weight:700; }
.menu-user { font-size:13px; color:var(–muted); margin-top:3px; }
.menu-item { padding:16px 20px; display:flex; align-items:center; gap:14px; border-bottom:1px solid var(–bg); cursor:pointer; font-size:16px; font-weight:500; }
.menu-item:active { background:var(–bg); }
.menu-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; }
.menu-close { position:absolute; top:16px; right:16px; background:none; border:none; font-size:22px; cursor:pointer; color:var(–muted); z-index:52; }

/* ── CONFIRM ── */
#confirmScreen { background:#1C1C1E; }
.conf-nav { padding:20px; text-align:center; color:#fff; font-size:17px; font-weight:600; }
.conf-body { flex:1; display:flex; flex-direction:column; align-items:center; padding:12px 32px 36px; }
.conf-icon { width:110px; height:110px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:18px; box-shadow:0 8px 24px rgba(0,0,0,.4); }
.conf-icon svg { width:58px; height:58px; }
.conf-title { color:#fff; font-size:24px; font-weight:800; text-align:center; margin-bottom:16px; }
.subtype-pill { background:#3A3A3C; color:#EBEBF5; border:none; border-radius:20px; padding:8px 20px; font-size:14px; cursor:pointer; font-family:inherit; margin-bottom:44px; }
.slide-wrap { width:100%; height:62px; background:#3A3A3C; border-radius:31px; position:relative; overflow:hidden; margin-bottom:24px; user-select:none; }
.slide-label { position:absolute; top:50%; right:20px; transform:translateY(-50%); color:rgba(255,255,255,.65); font-size:15px; font-weight:600; pointer-events:none; white-space:nowrap; }
.slide-handle { position:absolute; left:3px; top:3px; width:56px; height:56px; border-radius:50%; background:#fff; cursor:grab; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 10px rgba(0,0,0,.35); z-index:2; }
.cancel-circle { width:54px; height:54px; border-radius:50%; background:#3A3A3C; border:none; display:flex; align-items:center; justify-content:center; cursor:pointer; color:#fff; font-size:20px; }
.cancel-lbl { color:rgba(255,255,255,.55); font-size:12px; margin-top:4px; }

/* ── ACTIVE INCIDENT ── */
#activeScreen { background:var(–bg); }
.inc-scroll { flex:1; overflow-y:auto; }
.inc-header { background:#fff; padding:18px 20px; display:flex; flex-direction:column; align-items:center; text-align:center; border-bottom:1px solid var(–border); }
.inc-icon { width:84px; height:84px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:10px; box-shadow:0 4px 14px rgba(0,0,0,.15); }
.inc-icon svg { width:44px; height:44px; }
.inc-title { font-size:20px; font-weight:800; margin-bottom:2px; }
.inc-school { font-size:15px; font-weight:600; margin-bottom:4px; }
.inc-meta { font-size:13px; color:var(–muted); margin-bottom:6px; }
.inc-map { color:#007AFF; font-size:13px; font-weight:500; cursor:pointer; }
.qt-label { padding:16px 20px 8px; font-size:11px; font-weight:700; color:var(–orange); letter-spacing:.08em; text-transform:uppercase; text-align:center; }
.qt-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; padding:0 16px; }
.qt-btn { background:#fff; border:1.5px solid var(–border); border-radius:14px; padding:18px 12px; display:flex; flex-direction:column; align-items:center; gap:7px; cursor:pointer; font-size:14px; font-weight:600; }
.qt-btn:active { background:var(–bg); }
.qt-btn svg { width:24px; height:24px; }
.full-btn { margin:10px 16px 0; background:#fff; border:1.5px solid var(–border); border-radius:14px; padding:15px 18px; display:flex; align-items:center; gap:12px; cursor:pointer; font-size:14px; font-weight:600; }
.full-btn:active { background:var(–bg); }
.full-btn svg { width:20px; height:20px; flex-shrink:0; }
.full-btn:last-of-type { margin-bottom:14px; }

/* ── ROSTER ── */
#rosterScreen { background:var(–bg); }
.roster-top { background:#fff; padding:12px 20px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(–border); }
.ri-class { font-size:14px; font-weight:600; }
.ri-name { font-size:12px; color:var(–muted); margin-top:1px; }
.ri-count { font-size:13px; color:var(–muted); }
.ri-count b { color:var(–green); }
.sel-row { background:var(–bg); padding:7px 20px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(–border); }
.sel-all-btn { color:#007AFF; font-size:14px; background:none; border:none; cursor:pointer; font-family:inherit; }
.sel-ct { font-size:13px; color:var(–muted); }
.r-scroll { flex:1; overflow-y:auto; }
.r-item { background:#fff; padding:11px 20px; display:flex; align-items:center; gap:11px; border-bottom:1px solid var(–border); cursor:pointer; }
.r-item:active { background:#F9F9F9; }
.r-item.is-acc { opacity:.6; cursor:default; }
.r-check { width:24px; height:24px; border-radius:50%; border:2px solid #C7C7CC; flex-shrink:0; display:flex; align-items:center; justify-content:center; transition:all .12s; }
.r-check.on { background:var(–green); border-color:var(–green); }
.r-check.on::after { content:’’; display:block; width:9px; height:5px; border-left:2.5px solid #fff; border-bottom:2.5px solid #fff; transform:rotate(-45deg) translateY(-1px); }
.r-avatar { width:34px; height:34px; border-radius:50%; background:#E5E5EA; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:600; color:#555; flex-shrink:0; }
.r-name { font-size:15px; flex:1; }
.r-badge { font-size:10px; font-weight:700; padding:2px 8px; border-radius:20px; }
.r-badge.acc { background:#D1FAE5; color:#065F46; }
.r-badge.unk { background:#FEF3C7; color:#92400E; }
.r-badge.abs { background:#E5E7EB; color:#374151; }
.r-badge.mis { background:#FEE2E2; color:#991B1B; }
.r-badge.inj { background:#FEF3C7; color:#92400E; }
.update-bar { background:#fff; border-top:1px solid var(–border); padding:12px 20px 26px; flex-shrink:0; }

/* ── STATUS PICKER ── */
#statusPickScreen { background:var(–bg); }
.status-options { padding:12px 16px; display:flex; flex-direction:column; gap:10px; }
.status-opt { background:#fff; border:2px solid var(–border); border-radius:14px; padding:16px 20px; display:flex; align-items:center; gap:14px; cursor:pointer; transition:border-color .15s; }
.status-opt:active { background:var(–bg); }
.status-opt.sel { border-color:var(–orange); background:#FFF9F0; }
.so-dot { width:14px; height:14px; border-radius:50%; flex-shrink:0; }
.so-label { font-size:16px; font-weight:600; }
.so-desc { font-size:12px; color:var(–muted); margin-top:2px; }

/* ── LOCATION ── */
#locationScreen { background:var(–bg); }
.loc-hdr { background:#fff; padding:16px 20px 12px; border-bottom:1px solid var(–border); }
.loc-title { font-size:18px; font-weight:700; margin-bottom:3px; }
.loc-sub { font-size:13px; color:var(–muted); }
.loc-item { background:#fff; padding:13px 20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(–border); cursor:pointer; }
.loc-item:active { background:var(–bg); }
.loc-name { font-size:15px; font-weight:500; }
.loc-type { font-size:12px; color:var(–muted); margin-top:1px; }
.loc-radio { width:22px; height:22px; border-radius:50%; border:2px solid #C7C7CC; display:flex; align-items:center; justify-content:center; }
.loc-radio.sel { border-color:var(–orange); background:var(–orange); }
.loc-radio.sel::after { content:’’; display:block; width:8px; height:8px; background:#fff; border-radius:50%; }

/* ── SUCCESS ── */
#successScreen { background:#fff; align-items:center; justify-content:center; text-align:center; padding:40px 28px; }
.suc-check { width:76px; height:76px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 18px; color:#fff; font-size:36px; animation:pop .4s cubic-bezier(.175,.885,.32,1.275); }
@keyframes pop { from{transform:scale(0)}to{transform:scale(1)} }
.suc-title { font-size:20px; font-weight:700; margin-bottom:6px; }
.suc-sub { font-size:14px; color:var(–muted); line-height:1.5; margin-bottom:5px; }
.suc-loc { font-size:14px; font-weight:600; margin-bottom:28px; }

/* ── REUNIFICATION ROLE ── */
#reuniRoleScreen { background:var(–bg); }
.role-options { padding:16px; display:flex; flex-direction:column; gap:12px; }
.role-card { background:#fff; border:2px solid var(–border); border-radius:16px; padding:18px 20px; display:flex; align-items:center; gap:16px; cursor:pointer; transition:border-color .15s; }
.role-card:active { background:var(–bg); }
.role-icon { width:48px; height:48px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
.role-title { font-size:17px; font-weight:700; }
.role-desc { font-size:12px; color:var(–muted); margin-top:2px; }

/* ── GREETER ── */
#greeterScreen { background:var(–bg); }
.search-box { background:#fff; padding:12px 16px; border-bottom:1px solid var(–border); }
.search-input-wrap { background:var(–bg); border-radius:10px; display:flex; align-items:center; gap:8px; padding:8px 12px; }
.search-input-wrap svg { width:16px; height:16px; flex-shrink:0; color:var(–muted); }
.search-input { background:none; border:none; outline:none; font-size:16px; font-family:inherit; flex:1; color:var(–text); }
.search-input::placeholder { color:#AEB0B5; }
.search-results { flex:1; overflow-y:auto; }
.search-item { background:#fff; padding:13px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid var(–border); cursor:pointer; }
.search-item:active { background:var(–bg); }
.s-avatar { width:40px; height:40px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:14px; font-weight:700; color:#fff; flex-shrink:0; }
.s-name { font-size:16px; font-weight:500; }
.s-grade { font-size:13px; color:var(–muted); }
.search-empty { padding:40px 20px; text-align:center; color:var(–muted); font-size:15px; }

/* ── STUDENT DETAIL (GREETER) ── */
#studentDetailScreen { background:var(–bg); overflow-y:auto; }
.stu-hero { background:#fff; padding:24px 20px 20px; display:flex; flex-direction:column; align-items:center; border-bottom:1px solid var(–border); }
.stu-photo { width:80px; height:80px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:28px; font-weight:700; color:#fff; margin-bottom:10px; }
.stu-name { font-size:20px; font-weight:700; margin-bottom:3px; }
.stu-info { font-size:13px; color:var(–muted); }
.section-label { padding:14px 20px 8px; font-size:12px; font-weight:700; color:var(–muted); text-transform:uppercase; letter-spacing:.06em; }
.guardian-card { background:#fff; margin:0; padding:14px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid var(–border); cursor:pointer; }
.guardian-card:active { background:var(–bg); }
.guardian-card.sel { background:#FFF3E0; border-left:3px solid var(–orange); }
.g-avatar { width:38px; height:38px; border-radius:50%; background:#E5E5EA; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:700; color:#555; flex-shrink:0; }
.g-name { font-size:15px; font-weight:600; }
.g-rel { font-size:12px; color:var(–muted); margin-top:2px; }
.g-phone { font-size:12px; color:#007AFF; margin-top:2px; }
.g-sel-indicator { margin-left:auto; width:22px; height:22px; border-radius:50%; border:2px solid #C7C7CC; display:flex; align-items:center; justify-content:center; }
.g-sel-indicator.on { background:var(–orange); border-color:var(–orange); }
.g-sel-indicator.on::after { content:’’; display:block; width:8px; height:5px; border-left:2px solid #fff; border-bottom:2px solid #fff; transform:rotate(-45deg) translateY(-1px); }

/* ── POPUP / MODAL ── */
.modal-overlay { display:none; position:absolute; inset:0; background:rgba(0,0,0,.5); z-index:80; align-items:flex-end; }
.modal-overlay.open { display:flex; }
.modal-sheet { background:#fff; border-radius:20px 20px 0 0; padding:24px 24px 36px; width:100%; }
.modal-title { font-size:18px; font-weight:700; margin-bottom:6px; text-align:center; }
.modal-sub { font-size:14px; color:var(–muted); text-align:center; margin-bottom:22px; line-height:1.5; }
.modal-id-badge { background:var(–bg); border-radius:12px; padding:14px 16px; margin-bottom:20px; display:flex; align-items:center; gap:12px; }
.modal-id-badge svg { width:28px; height:28px; flex-shrink:0; }
.modal-id-name { font-size:15px; font-weight:700; }
.modal-id-sub { font-size:12px; color:var(–muted); }
.modal-btns { display:flex; gap:10px; }
.modal-btn { flex:1; border:none; border-radius:12px; padding:14px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; }
.modal-btn.verified { background:var(–green); color:#fff; }
.modal-btn.unverified { background:#F3F4F6; color:#374151; }

/* ── RUNNER ── */
#runnerScreen { background:var(–bg); }
.runner-scroll { flex:1; overflow-y:auto; }
.runner-header { background:#fff; padding:18px 20px; border-bottom:1px solid var(–border); }
.runner-title { font-size:18px; font-weight:700; margin-bottom:4px; }
.runner-sub { font-size:13px; color:var(–muted); }
.queue-card { background:#fff; margin:12px 16px 0; border-radius:14px; padding:16px; border:1.5px solid var(–border); display:flex; align-items:center; gap:12px; }
.queue-num { width:32px; height:32px; border-radius:50%; background:var(–orange); color:#fff; font-size:14px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.queue-name { font-size:15px; font-weight:600; }
.queue-grade { font-size:12px; color:var(–muted); }
.runner-bottom { padding:16px; flex-shrink:0; }
.retrieve-btn { width:100%; background:var(–green); color:#fff; border:none; border-radius:14px; padding:16px; font-size:17px; font-weight:700; cursor:pointer; font-family:inherit; display:flex; align-items:center; justify-content:center; gap:8px; }

/* ── REUNIFY STUDENT ── */
#reunifyScreen { background:var(–bg); overflow-y:auto; }
.reuni-hero { background:#fff; padding:20px; border-bottom:1px solid var(–border); display:flex; align-items:center; gap:14px; }
.reuni-photo { width:56px; height:56px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:700; color:#fff; flex-shrink:0; }
.reuni-stu-name { font-size:17px; font-weight:700; }
.reuni-stu-info { font-size:13px; color:var(–muted); margin-top:2px; }
.reuni-guardian-block { background:#fff; margin:12px 16px 0; border-radius:14px; padding:16px; border:1.5px solid var(–border); }
.rgb-label { font-size:11px; font-weight:700; color:var(–muted); text-transform:uppercase; letter-spacing:.06em; margin-bottom:10px; }
.rgb-name { font-size:16px; font-weight:700; margin-bottom:3px; }
.rgb-rel { font-size:13px; color:var(–muted); margin-bottom:3px; }
.rgb-phone { font-size:13px; color:#007AFF; }
.reuni-action-row { display:flex; gap:10px; margin:14px 16px 0; }
.reuni-action-btn { flex:1; border:none; border-radius:12px; padding:14px; font-size:14px; font-weight:700; cursor:pointer; font-family:inherit; }
.reuni-action-btn.primary { background:var(–orange); color:#fff; }
.reuni-action-btn.secondary { background:#F3F4F6; color:var(–text); }

/* ── SIGNATURE ── */
#signatureScreen { background:var(–bg); }
.sig-scroll { flex:1; overflow-y:auto; }
.sig-header { background:#fff; padding:16px 20px; border-bottom:1px solid var(–border); }
.sig-title { font-size:18px; font-weight:700; margin-bottom:3px; }
.sig-sub { font-size:13px; color:var(–muted); }
.sig-summary { background:#fff; margin:12px 16px 0; border-radius:14px; padding:16px; border:1.5px solid var(–border); }
.sig-row { display:flex; gap:12px; align-items:center; margin-bottom:12px; }
.sig-row:last-child { margin-bottom:0; }
.sig-row-icon { font-size:20px; width:28px; text-align:center; }
.sig-row-label { font-size:12px; color:var(–muted); }
.sig-row-val { font-size:15px; font-weight:600; }
.sig-canvas-wrap { background:#fff; margin:12px 16px 0; border-radius:14px; border:1.5px solid var(–border); overflow:hidden; }
.sig-canvas-label { padding:12px 16px 6px; font-size:12px; font-weight:700; color:var(–muted); text-transform:uppercase; letter-spacing:.06em; }
canvas#sigCanvas { width:100%; height:140px; cursor:crosshair; display:block; }
