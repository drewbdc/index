function filterStudents(q){
  const res=document.getElementById('greeterResults');
  if(!q.trim()){ res.innerHTML='<div class="search-empty">Start typing to find a student</div>'; return; }
  const matches=STUDENTS.filter(s=>s.name.toLowerCase().includes(q.toLowerCase()));
  if(!matches.length){ res.innerHTML='<div class="search-empty">No students found</div>'; return; }
  res.innerHTML='';
  matches.forEach(s=>{
    const initials=s.name.split(' ').map(n=>n[0]).join('');
    const div=document.createElement('div'); div.className='search-item';
    div.innerHTML=`<div class="s-avatar" style="background:${s.color}">${initials}</div><div><div class="s-name">${s.name}</div><div class="s-grade">Grade ${s.grade} · ${s.room}</div></div>`;
