  clearSig();
  sigCtx.strokeStyle='#1C1C1E'; sigCtx.lineWidth=2.5; sigCtx.lineCap='round'; sigCtx.lineJoin='round';
  const getPos=e=>{ const r=c.getBoundingClientRect(),t=e.touches?e.touches[0]:e; return{x:(t.clientX-r.left)*(c.width/r.width),y:(t.clientY-r.top)*(c.height/r.height)}; };
  c.addEventListener('mousedown',e=>{ sigDrawing=true; const p=getPos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); });
  c.addEventListener('touchstart',e=>{ sigDrawing=true; const p=getPos(e); sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); e.preventDefault(); },{passive:false});
  c.addEventListener('mousemove',e=>{ if(!sigDrawing)return; const p=getPos(e); sigCtx.lineTo(p.x,p.y); sigCtx.stroke(); });
  c.addEventListener('touchmove',e=>{ if(!sigDrawing)return; const p=getPos(e); sigCtx.lineTo(p.x,p.y); sigCtx.stroke(); e.preventDefault(); },{passive:false});
  c.addEventListener('mouseup',()=>sigDrawing=false);
  c.addEventListener('touchend',()=>sigDrawing=false);
}

function completeReunification(){
  // Remove from queue
  greeterQueue.shift();
  const now=new Date();
  const dateStr=now.toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'})+' at '+now.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  document.getElementById('cMsgStu').textContent=currentStudent.name;
  document.getElementById('cMsgG').textContent=currentGuardian.name;
  document.getElementById('cMsgSchool').textContent=userSchool;
  document.getElementById('cMsgDate').textContent=dateStr;
  document.getElementById('cMsgTime').textContent=now.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
  goTo('completeScreen');
}

// Observe signatureScreen activation to init canvas
const obs=new MutationObserver(()=>{ if(document.getElementById('signatureScreen').classList.contains('active')) initSig(); });
obs.observe(document.getElementById('signatureScreen'),{attributeFilter:['class']});

buildRoster();
</script>

