function initSlide(color){
  const wrap=document.getElementById('slideWrap'),handle=document.getElementById('slideHandle'),label=document.getElementById('slideLabel');
  handle.style.transition='none'; handle.style.left='3px'; label.textContent='Initiate Emergency';
  let drag=false,sx=0,cl=3;
  const newH=handle.cloneNode(true); handle.parentNode.replaceChild(newH,handle);
  newH.addEventListener('mousedown',e=>{ drag=true; sx=(e.touches?e.touches[0].clientX:e.clientX)-cl; newH.style.transition='none'; });
  newH.addEventListener('touchstart',e=>{ drag=true; sx=e.touches[0].clientX-cl; newH.style.transition='none'; },{passive:true});
  document.addEventListener('mousemove',e=>{ if(!drag)return; const max=wrap.offsetWidth-60; cl=Math.max(3,Math.min(e.clientX-sx,max)); newH.style.left=cl+'px'; label.textContent=cl>max*.3?'Slide to Initiate →':'Initiate Emergency'; if(cl>=max-8){drag=false;goTo('activeScreen');} });
  document.addEventListener('touchmove',e=>{ if(!drag)return; const max=wrap.offsetWidth-60; cl=Math.max(3,Math.min(e.touches[0].clientX-sx,max)); newH.style.left=cl+'px'; label.textContent=cl>max*.3?'Slide to Initiate →':'Initiate Emergency'; if(cl>=max-8){drag=false;goTo('activeScreen');} },{passive:true});
  const onUp=()=>{ if(!drag)return; drag=false; newH.style.transition='left .3s'; newH.style.left='3px'; cl=3; label.textContent='Initiate Emergency'; };
  document.addEventListener('mouseup',onUp); document.addEventListener('touchend',onUp);
}

